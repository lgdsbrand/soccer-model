# API-Football (api-football.com — free tier: 100 req/day)
# Get key at: https://dashboard.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# OpenWeatherMap (free: 1000 calls/day)
# Get key at: https://openweathermap.org/api
OPENWEATHERMAP_KEY=your_openweathermap_key_here

# Tavily (free: 1000 searches/month)
# Get key at: https://tavily.com
TAVILY_KEY=your_tavily_key_here

# Groq (fast LLM inference, very cheap)
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Google GenAI / Gemini (for full AI analysis)
# Get key at: https://aistudio.google.com
GOOGLE_GENAI_KEY=your_google_genai_key_here

# App settings
APP_ENV=development
FRONTEND_URL=http://localhost:3000
